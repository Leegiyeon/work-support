# Root compose defaults for local development only.
# Copy to .env and adjust as needed. Do not commit real secrets.

POSTGRES_DB=work_support
POSTGRES_USER=work_support
POSTGRES_PASSWORD=work_support_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://work_support:work_support_dev_password@db:5432/work_support

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Docker Compose frontend server routes use the backend service name.
# For local frontend outside Docker, use frontend/.env.example instead.
WORK_SUPPORT_BACKEND_URL=http://backend:8000
FRONTEND_ORIGIN=http://localhost:3000

# OpenAI is intentionally not used by the skeleton yet.
OPENAI_API_KEY=

# Local storage is the MVP default. S3/Supabase Storage adapters can be added later.
LOCAL_STORAGE_ROOT=/app/storage/uploads
# Local-only report access guard. Replace before any non-local exposure.
DEFAULT_OWNER_ID=local-owner
REPORT_ACCESS_TOKEN=dev-only-report-token
# The compose frontend maps these server-only values from DEFAULT_OWNER_ID/REPORT_ACCESS_TOKEN.
NEXT_PUBLIC_WORK_SUPPORT_OWNER_ID=local-owner
REPORT_TIMEZONE=Asia/Seoul
